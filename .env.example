# Flask Configuration
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
SESSION_COOKIE_SECURE=False  # Set to True when deploying with HTTPS

# Database (PostgreSQL recommended for production)
DATABASE_URL=sqlite:///users.db  # Or postgresql://user:password@localhost/dbname

# Razorpay Payment Configuration
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_MONTHLY_PLAN_ID=plan_xxxxxxxxxxxxxxxxxx
RAZORPAY_YEARLY_PLAN_ID=plan_xxxxxxxxxxxxxxxxxx
# Webhook secret: Razorpay Dashboard -> Settings -> Webhooks.
# Point the webhook at https://<your-domain>/razorpay-webhook with events
# subscription.activated + subscription.charged, and use the same secret here.
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Proxy for Binance if your server region is geo-blocked (e.g. US Google Cloud regions)
# PROXY_URL=http://user:pass@proxy-host:port

# Binance API (Optional - for default/demo trading)
BINANCE_KEY=your-binance-api-key
BINANCE_SECRET=your-binance-secret-key

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SMTP Email (Optional - for notifications)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

